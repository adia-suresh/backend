{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "./mvnw clean package -DskipTests"
  },
  "deploy": {
    "startCommand": "java -Dserver.port=$PORT -Djava.net.preferIPv4Stack=true -Dserver.address=0.0.0.0 -jar target/SpringBootSDPBackendProject-0.0.1-SNAPSHOT.jar",
    "restartPolicyType": "ON_FAILURE"
  }
}
